<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="ca.dnamobile.javalauncher">

    <!-- ===================== Permissions ===================== -->

    <!-- Networking: downloading versions/libraries/assets, Microsoft device-code auth, mod/modpack downloads -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Storage: game files, instances, mods, resource/shader packs, logs live under external storage -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Android 13+ visible progress/foreground notifications (install/unpack progress) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- In-game voice chat / mic input (Simple Voice Chat mod compat) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Bluetooth game controllers -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Controller rumble / haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Keep the CPU/GPU alive during long installs/unpacks -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Required on Android 11+ so the launcher can actually see installed renderer/plugin
         packages when it falls back to querying installed packages. Explicit package
         entries below cover the known renderer plugins; the pattern queries cover
         mod-loader/companion apps that show up under similar namespaces. -->
    <queries>
        <package android:name="com.fcl.plugin.mobileglues" />
        <package android:name="com.bzlzhh.plugin.ngg" />
        <package android:name="com.bzlzhh.plugin.ngg.angleless" />
        <package android:name="com.mio.plugin.renderer.gl4es" />
        <package android:name="com.mio.plugin.renderer.mesa2500.rc1" />
        <package android:name="com.mio.plugin.renderer.mobileglues" />
        <package android:name="com.mio.plugin.renderer.ltw" />
        <package android:name="com.mio.plugin.renderer.angle" />
        <package android:name="com.mio.plugin.renderer.mesa2319" />
        <package android:name="com.mio.plugin.renderer.mesa2427" />
        <package android:name="com.mio.plugin.renderer.mesa2434" />
        <package android:name="com.mio.plugin.renderer.mesa2500" />
        <package android:name="com.fcl.plugin.renderer.mobileglues" />
        <package android:name="com.fcl.plugin.renderer.ltw" />
        <package android:name="com.fcl.plugin.renderer.gl4es" />
        <package android:name="com.fcl.plugin.renderer.angle" />
        <package android:name="com.fcl.plugin.renderer.mesa" />

        <!-- Opening links from legal pages / update checker / device-code sign-in -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <!-- ===================== Hardware / feature declarations ===================== -->
    <!-- This is a controller/keyboard-first launcher: don't gate installs on touchscreen -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.gamepad"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.vulkan.version"
        android:required="false" />
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />

    <application
        android:name="androidx.multidex.MultiDexApplication"
        android:allowBackup="false"
        android:extractNativeLibs="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher_droidbridge"
        android:roundIcon="@mipmap/ic_launcher_droidbridge_round"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <!-- ================= Entry point ================= -->
        <activity
            android:name="ca.dnamobile.javalauncher.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ================= Game surface (PojavLauncher-derived) ================= -->
        <activity
            android:name="org.libsdl.app.SDLActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode|navigation|keyboard"
            android:hardwareAccelerated="true"
            android:launchMode="singleTask"
            android:screenOrientation="userLandscape"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <!-- ================= Launcher UI ================= -->
        <activity
            android:name="ca.dnamobile.javalauncher.LauncherSettingsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:parentActivityName="ca.dnamobile.javalauncher.SplashActivity" />

        <activity
            android:name="ca.dnamobile.javalauncher.ModpackUpdateDetailsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode" />

        <activity
            android:name="ca.dnamobile.javalauncher.ErrorActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:process=":error" />

        <activity
            android:name="ca.dnamobile.javalauncher.controls.ControlsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode" />

        <activity
            android:name="ca.dnamobile.javalauncher.controls.ControlsEditorActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode" />

        <activity
            android:name="ca.dnamobile.javalauncher.settings.SimpleVoiceChatPermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- ================= Storage Access Framework provider ================= -->
        <provider
            android:name="ca.dnamobile.javalauncher.storage.JavaLauncherDocumentsProvider"
            android:authorities="${applicationId}.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

        <!-- FileProvider for sharing exported worlds/logs/screenshots with other apps -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
